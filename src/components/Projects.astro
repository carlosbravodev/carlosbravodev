---
import ProjectCard from "./ProjectCard.astro";
import { Image } from "astro:assets";
import vticketsImg from "../assets/vtickets-project.webp";
import bequImg from "../assets/bequ-project.webp";
---

<section
  id="projects"
  class="min-h-screen py-20 px-6 font-brico bg-white border-t-4 border-black relative overflow-hidden"
>
  <!-- Decorative Background Pattern -->
  <div class="absolute inset-0 pattern-grid opacity-10 pointer-events-none">
  </div>

  <div class="container mx-auto relative z-10">
    <!-- Section Title -->
    <div class="flex justify-center mb-20">
      <div
        class="inline-block bg-lime-300 border-4 border-black rounded-2xl px-12 py-5 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transform rotate-2 hover:rotate-0 transition-transform duration-300"
      >
        <h2 class="text-4xl md:text-6xl font-black text-black">
          Selected Projects
        </h2>
      </div>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
      <!-- Project 1 -->
      <ProjectCard
        title="v-tickets"
        description="Complete ticketing platform for events with secure QR codes."
        colorClass="bg-purple-400"
        tags={[
          { label: "SvelteKit 5", colorClass: "bg-white" },
          { label: "TypeScript", colorClass: "bg-white" },
          { label: "Tailwind", colorClass: "bg-white" },
          { label: "Supabase", colorClass: "bg-white" },
          { label: "Lemon Squeezy", colorClass: "bg-white" },
        ]}
        demoLink="https://vtickets-8p5e.vercel.app/"
        repoLink="https://github.com/carlosbravodev/vtickets"
      >
        <div class="w-full group relative">
          <Image
            src={vticketsImg}
            alt="v-tickets project"
            class="w-full h-auto group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute top-4 right-4 animate-bounce-slow z-10">
            <span
              class="bg-white border-2 border-black px-3 py-1 font-bold rounded-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transform rotate-3 text-sm"
              >New</span
            >
          </div>
        </div>
      </ProjectCard>

      <!-- Project 2 -->
      <ProjectCard
        title="BeQu | Web Agency"
        description="Web design and development agency for professionals and businesses. SEO and automation."
        colorClass="bg-blue-400"
        tags={[
          { label: "Astro", colorClass: "bg-white" },
          { label: "Tailwind", colorClass: "bg-white" },
          { label: "TypeScript", colorClass: "bg-white" },
          { label: "Resend", colorClass: "bg-white" },
        ]}
        demoLink="https://www.bequweb.es/"
        repoLink="https://github.com/carlosbravodev/bequweb"
      >
        <div class="w-full group relative">
          <Image
            src={bequImg}
            alt="BeQu Web Agency project"
            class="w-full h-auto group-hover:scale-105 transition-transform duration-500"
          />
        </div>
      </ProjectCard>
    </div>
  </div>
</section>

<style>
  .pattern-grid {
    background-image:
      linear-gradient(#000 1px, transparent 1px),
      linear-gradient(90deg, #000 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .pattern-dots {
    background-image: radial-gradient(circle, #000 2px, transparent 2.5px);
    background-size: 20px 20px;
  }
</style>
